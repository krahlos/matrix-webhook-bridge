---
# Matrix Webhook Bridge Configuration

matrix:
  # Base URL of the Matrix homeserver (required)
  base_url: https://matrix.example.com

  # Target room ID for webhook notifications (required)
  room_id: "!roomid:matrix.example.com"

  # Matrix homeserver domain (required)
  domain: matrix.example.com

  # Timeout for Matrix API requests in seconds (default: 5)
  timeout: 5

  # Automatically join all configured rooms at startup (default: false)
  # autojoin: false

server:
  # Port to listen on (default: 5001)
  port: 5001

  # Fallback Matrix user localpart (default: "bridge")
  default_user: bridge

  # Optional shared secret for incoming webhook authentication.
  # When set, all POST requests must include an Authorization header:
  #   Authorization: Bearer <webhook_secret>
  # webhook_secret: your-secret-here

  # Map each ?service= value to the Matrix user localpart that should send the message.
  # If a service is not listed here, default_user is used.
  # service_users:
  #   alertmanager: alertmanager
  #   borgmatic: borgmatic
  #   crowdsec: crowdsec

  # Map each ?service= value to one or more Matrix room IDs.
  # If a service is not listed here, matrix.room_id is used.
  # Callers can also pass ?room=!id:domain to target a specific room per request.
  # service_rooms:
  #   alertmanager:
  #     - "!abc123:matrix.example.org"
  #     - "!def456:matrix.example.org"
  #   borgmatic:
  #     - "!abc123:matrix.example.org"
