{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/post-tool-use-markdownlint.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/post-tool-use-shfmt.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/post-tool-use-ruff.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/post-tool-use-actionlint.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ]
  },
  "permissions": {
    "allow": [],
    "ask": [],
    "deny": []
  }
}
